<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_darkmode"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    android:background="@color/Background"
    tools:context=".DarkModeActivity"
    tools:ignore="HardcodedText">

    <!-- 顶部栏(compose搭建) -->
    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/TopBarCompose"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="10dp"
        />

    <!-- 内容区域 -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/ScrollContentRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <!-- 顶部装饰 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="5dp"
                android:layout_marginTop="2dp"
                android:backgroundTint="@color/ContentCard_Background"
                app:cardCornerRadius="15dp"
                app:cardElevation="5dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">
                    <ImageView
                        android:id="@+id/sign_dark_mode"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_tile_dark_mode"
                        android:contentDescription="壁纸"
                        android:layout_gravity="center"
                        android:layout_marginStart="15dp"
                        android:scaleType="fitCenter" />
                    <HorizontalScrollView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:scrollbars="none"
                        android:layout_margin="11dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="为深色或浅色模式分别设置壁纸，并提供便捷设置的方法"
                            android:textColor="@color/HeadText"
                            android:textSize="13sp"
                            />
                    </HorizontalScrollView>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <!-- 壁纸卡 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="5dp"
                android:layout_marginTop="2dp"
                android:backgroundTint="@color/ContentCard_Background"
                app:cardCornerRadius="15dp"
                app:cardElevation="5dp">
                <!--  壁纸展示区 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal">
                    <!-- 左卡 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:layout_weight="1">
                        <!-- 左卡图片 -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardViewDark"
                            android:layout_width="match_parent"
                            android:layout_height="320dp"
                            android:layout_marginTop="20dp"
                            android:layout_marginStart="20dp"
                            android:layout_marginEnd="10dp"
                            android:backgroundTint="@color/Background2"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="5dp">
                            <ImageView
                                android:id="@+id/imageDark"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                />
                        </androidx.cardview.widget.CardView>
                        <!-- 左卡文字 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="30dp"
                            android:layout_marginBottom="10dp"
                            android:layout_marginStart="15dp"
                            android:layout_marginEnd="5dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="深色模式壁纸"
                                android:layout_gravity="center"
                                android:layout_marginStart="12dp"
                                android:textColor="@color/HeadText"
                                android:textSize="11sp"
                                android:layout_weight="0"/>
                            <View
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"/>
                            <TextView
                                android:id="@+id/buttonChangeDark"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="15dp"
                                android:text="更换"
                                android:layout_gravity="end|center"
                                android:textColor="@color/HeadText"
                                android:textSize="11sp"
                                android:layout_weight="0"/>
                        </LinearLayout>
                    </LinearLayout>
                    <!-- 右卡 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:layout_weight="1">
                        <!-- 右卡图片 -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardViewLight"
                            android:layout_width="match_parent"
                            android:layout_height="320dp"
                            android:layout_marginStart="10dp"
                            android:layout_marginTop="20dp"
                            android:layout_marginEnd="20dp"
                            android:backgroundTint="@color/Background2"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="5dp">
                            <ImageView
                                android:id="@+id/imageLight"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_weight="0"
                                android:contentDescription="1"
                                android:scaleType="centerCrop"
                                />
                        </androidx.cardview.widget.CardView>
                        <!-- 右卡文字 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="30dp"
                            android:layout_marginBottom="10dp"
                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="10dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="浅色模式壁纸"
                                android:layout_gravity="center"
                                android:layout_marginStart="12dp"
                                android:textColor="@color/HeadText"
                                android:textSize="11sp"
                                android:layout_weight="0"/>
                            <View
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"/>
                            <TextView
                                android:id="@+id/buttonChangeLight"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="15dp"
                                android:text="更换"
                                android:layout_gravity="end|center"
                                android:textColor="@color/HeadText"
                                android:textSize="11sp"
                                android:layout_weight="0"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <!-- 按钮区 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="15dp"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <Button
                    android:id="@+id/buttonSuperExit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/ButtonBg"
                    android:elevation="20dp"
                    android:text="返回桌面"
                    android:textColor="@color/ButtonText" />
                <Button
                    android:id="@+id/buttonSwitchDark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/ButtonBg"
                    android:text="@string/dark_mode_paper_apply_notice_dark"
                    android:textColor="@color/ButtonText" />
                <Button
                    android:id="@+id/buttonSwitchLight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/ButtonBg"
                    android:text="@string/dark_mode_paper_apply_notice_light"
                    android:textColor="@color/ButtonText" />
                <Button
                    android:id="@+id/buttonAddTile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/ButtonBg"
                    android:text="添加快捷方式"
                    android:textColor="@color/ButtonText" />
                <Button
                    android:id="@+id/buttonClear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/ButtonBg"
                    android:text="清除壁纸"
                    android:textColor="@color/ButtonText" />

            </LinearLayout>
            <!-- ExplanationCompose -->
            <androidx.compose.ui.platform.ComposeView
                android:id="@+id/ExplanationCompose"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>